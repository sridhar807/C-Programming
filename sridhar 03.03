//Write a program to calculate $x^y$ using the pow() function from <math.h>.
#include <stdio.h>
#include <math.h>
int main() {
    double base, exponent, result;
    printf("Enter base (x): ");
    scanf("%lf", &base);
    printf("Enter exponent (y): ");
    scanf("%lf", &exponent);
    result = pow(base, exponent);
    printf("%.2lf^%.2lf = %.2lf\n", base, exponent, result);
    return 0;
}
//Create a program using switch to check if a character is a Vowel or Consonant.
#include <stdio.h>
int main() {
    char ch;
    printf("Enter a character: ");
    scanf("%c", &ch);
    if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u' ||
        ch == 'A' || ch == 'E' || ch == 'I' || ch == 'O' || ch == 'U') {
        printf("%c is a vowel.", ch);
    } else {
        printf("%c is a consonant.", ch);
    }
    return 0;
}
//Write a program to print the Fibonacci series up to 50 using iteration.
#include <stdio.h>
int main() {
    int n1 = 0, n2 = 1, nextTerm;
    printf("Fibonacci Series up to 50: %d, %d, ", n1, n2);
    nextTerm = n1 + n2;
    while (nextTerm <= 50) {
        printf("%d, ", nextTerm);
        n1 = n2;
        n2 = nextTerm;
        nextTerm = n1 + n2;
    }
    printf("\n");
    return 0;
}
//Implement a program to check if a number is an Armstrong Number.
#include <stdio.h>
int main() {
    int number, originalNumber, remainder;
    int n = 0, i;
    int result = 0, power;
    printf("Enter an integer: ");
    scanf("%d", &number);
    originalNumber = number;
    while (originalNumber != 0) {
        originalNumber /= 10;
        n++;
    }
    originalNumber = number;
    while (originalNumber != 0) {
        remainder = originalNumber % 10;
        power = 1;
        for (i = 0; i < n; i++) {
            power *= remainder;
        }
        result += power;
        originalNumber /= 10;
    }
    if (result == number)
        printf("%d is an Armstrong number.\n", number);
    else
        printf("%d is not an Armstrong number.\n", number);
    return 0;
}
//Write a program to generate all Prime Numbers between 1 and 100.
#include <stdio.h>
int main() {
    int i, j, isPrime;
    printf("Prime numbers between 1 and 100 are:\n");
    for(i = 2; i <= 100; i++) {
        isPrime = 1;  
        for(j = 2; j <= i / 2; j++) {
            if(i % j == 0) {
                isPrime = 0;  
                break;
            }
        }
        if(isPrime == 1) {
            printf("%d ", i);
        }
    }
    return 0;
}
//Create a program to sort an array of 5 integers in ascending order (Bubble Sort).
#include <stdio.h>
int main() {
    int arr[5], i, j, temp;
    printf("Enter 5 integers:\n");
    for(i = 0; i < 5; i++) {
        scanf("%d", &arr[i]);
    }
    for(i = 0; i < 4; i++) {
        for(j = 0; j < 4 - i; j++) {
            if(arr[j] > arr[j + 1]) {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
    printf("Sorted array in ascending order:\n");
    for(i = 0; i < 5; i++) {
        printf("%d ", arr[i]);
    }
    return 0;
}
//Write a program to merge two small arrays into a single larger array.
#include <stdio.h>
int main() {
    int arr1[5], arr2[5], merged[10];
    int i;
    printf("Enter 5 elements for first array:\n");
    for(i = 0; i < 5; i++) {
        scanf("%d", &arr1[i]);
    }
    printf("Enter 5 elements for second array:\n");
    for(i = 0; i < 5; i++) {
        scanf("%d", &arr2[i]);
    }
    for(i = 0; i < 5; i++) {
        merged[i] = arr1[i];
    }
    for(i = 0; i < 5; i++) {
        merged[i + 5] = arr2[i];
    }
    printf("Merged array:\n");
    for(i = 0; i < 10; i++) {
        printf("%d ", merged[i]);
    }
    return 0;
}
//Implement a program to find the frequency of a specific number in an array.
#include <stdio.h>
int main() {
    int arr[10], i, number, count = 0;
    printf("Enter 10 integers:\n");
    for(i = 0; i < 10; i++) {
        scanf("%d", &arr[i]);
    }
    printf("Enter the number to find frequency: ");
    scanf("%d", &number);
    for(i = 0; i < 10; i++) {
        if(arr[i] == number) {
            count++;
        }
    }
    printf("Frequency of %d = %d\n", number, count);
    return 0;
}
//Write a program to check if a 3x3 matrix is an Identity Matrix.
#include <stdio.h>
int main() {
    int matrix[3][3];
    int i, j;
    int isIdentity = 1;
    printf("Enter elements of 3x3 matrix:\n");
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 3; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }
    for(i = 0; i < 3; i++) {
        for(j = 0; j < 3; j++) {
            if(i == j) {
                if(matrix[i][j] != 1) {
                    isIdentity = 0;
                    break;
                }
            } else {
                if(matrix[i][j] != 0) {
                    isIdentity = 0;
                    break;
                }
            }
        }
    }
    if(isIdentity)
        printf("The matrix is an Identity Matrix.\n");
    else
        printf("The matrix is NOT an Identity Matrix.\n");

    return 0;
}
